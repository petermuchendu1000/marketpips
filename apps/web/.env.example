# MarketPips Environment Variables
# Copy this to .env.local and fill in your values

# ============================================================
# SUPABASE
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ============================================================
# APP CONFIG
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MarketPips
NEXT_PUBLIC_APP_DESCRIPTION=East Africa's Premier Prediction Market Platform
NODE_ENV=development

# ============================================================
# AUTHENTICATION
# ============================================================
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# ============================================================
# M-PESA (Safaricom - Kenya)
# Docs: https://developer.safaricom.co.ke/
# ============================================================
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-mpesa-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/webhooks/mpesa
MPESA_ENV=sandbox
# sandbox: https://sandbox.safaricom.co.ke
# production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# ============================================================
# MTN MOMO (Uganda, Rwanda, Ghana - MoMo API)
# Docs: https://momodeveloper.mtn.com/
# ============================================================
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your-subscription-key
MTN_MOMO_API_USER=your-api-user-uuid
MTN_MOMO_API_KEY=your-api-key
MTN_MOMO_CALLBACK_URL=https://your-domain.com/api/webhooks/mtn-momo
MTN_MOMO_ENV=sandbox
# sandbox | production

# ============================================================
# AIRTEL MONEY (Tanzania, Uganda, Kenya, Rwanda, Zambia)
# Docs: https://developers.airtel.africa/
# ============================================================
AIRTEL_MONEY_CLIENT_ID=your-airtel-client-id
AIRTEL_MONEY_CLIENT_SECRET=your-airtel-client-secret
AIRTEL_MONEY_CALLBACK_URL=https://your-domain.com/api/webhooks/airtel
AIRTEL_MONEY_ENV=sandbox
AIRTEL_MONEY_BASE_URL=https://openapiuat.airtel.africa

# ============================================================
# PESAPAL (Multi-currency East Africa)
# Supports: KES, UGX, TZS, RWF, ZMW
# Docs: https://developer.pesapal.com/
# ============================================================
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_IPN_URL=https://your-domain.com/api/webhooks/pesapal
PESAPAL_ENV=sandbox
# sandbox: https://cybqa.pesapal.com/pesapalv3
# production: https://pay.pesapal.com/v3
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3

# ============================================================
# CURRENCY & FINANCIAL CONFIG
# ============================================================
# Supported currencies: KES, UGX, TZS, RWF, ZMW, ETB, BIF
SUPPORTED_CURRENCIES=KES,UGX,TZS,RWF,ZMW
DEFAULT_CURRENCY=KES
# Fee percentage (e.g. 0.02 = 2%)
PLATFORM_FEE_RATE=0.02
# Minimum bet amounts per currency
MIN_BET_KES=50
MIN_BET_UGX=2000
MIN_BET_TZS=5000
MIN_BET_RWF=1000

# ============================================================
# OPEN EXCHANGE RATES (for currency conversion)
# Docs: https://openexchangerates.org/
# ============================================================
OPEN_EXCHANGE_RATES_APP_ID=your-open-exchange-rates-app-id

# ============================================================
# EMAIL (Resend - easy transactional email)
# Docs: https://resend.com/
# ============================================================
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=MarketPips <noreply@marketpips.co.ke>
EMAIL_FROM=noreply@marketpips.co.ke
EMAIL_REPLY_TO=support@marketpips.co.ke

# ============================================================
# SMS (Africa's Talking - covers EA countries)
# Docs: https://africastalking.com/
# ============================================================
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_SENDER_ID=MarketPips

# ============================================================
# REDIS / UPSTASH (rate limiting, caching)
# Docs: https://upstash.com/
# ============================================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ============================================================
# ADMIN
# ============================================================
ADMIN_SECRET_KEY=your-very-secret-admin-key-change-this

# ============================================================
# CRON / MARKET RESOLUTION
# ============================================================
CRON_SECRET=your-cron-secret-key

# ============================================================
# SENTRY (error monitoring - optional)
# ============================================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ============================================================
# VERCEL (auto-set by Vercel, leave blank locally)
# ============================================================
VERCEL_URL=
